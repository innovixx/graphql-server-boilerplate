{
  "name": "graphql-server-boilerplate",
  "version": "0.0.0",
  "description": "This GraphQL server boilerplate provides a basic structure for building servers.",
  "repository": "git@github.com:innovixx/graphql-server-boilerplate.git",
  "author": "Innovixx <support@innovixx.co.uk>",
  "type": "module",
  "scripts": {
    "dev": "pnpm generate:openapi & nodemon --exec tsx src/index.ts",
    "build": "pnpm generate:openapi && pnpm tsc && pnpm copyfiles",
    "serve": "node ./dist/index.js",
    "cleanDev": "pnpm db:reset && tsx ./src/seed/index.ts && pnpm dev",
    "db:migrate:main": "npx prisma migrate dev --schema './databases/maindb/schema.prisma' && npx tsx src/utils/convertPrismaToGql/index.ts ",
    "db:migrate:main:prod": "npx prisma migrate deploy --schema './databases/maindb/schema.prisma'",
    "db:reset": "npx prisma migrate reset --force --schema './databases/maindb/schema.prisma'",
    "generate:openapi": "npx tsx src/bin/generateOpenApi.ts",
    "copyfiles": "copyfiles -u 1 \"src/**/*.json\" \"src/**/index.graphql\" dist/",
    "lint": "eslint ./src/**/*.{js,jsx,ts,tsx,graphql}",
    "lint-staged": "lint-staged --verbose",
    "prepare": "if [ -d node_modules/husky ]; then husky; fi"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-codegen/cli": "^6.1.3",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/schema": "^10.0.31",
    "@graphql-tools/utils": "^11.0.0",
    "@parcel/watcher": "^2.5.6",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "graphql-parse-resolve-info": "^4.14.1",
    "graphql-tag": "^2.12.6",
    "helmet": "^8.1.0",
    "lodash.merge": "^4.6.2",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6",
    "zod-prisma-types": "^3.3.11"
  },
  "devDependencies": {
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@innovixx/eslint-config": "^3.0.11",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copyfiles": "^2.4.1",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "nodemon": "^3.1.14",
    "prisma-zod-generator": "^2.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.67.1"
  },
  "lint-staged": {
    "**/*.graphql": "eslint",
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --quiet",
      "bash -c tsc"
    ]
  }
}